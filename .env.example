# Required for Netlify Blobs to work locally (outside of `netlify dev`)
# Get these from: https://app.netlify.com → Site settings → General → Site information
NETLIFY_SITE_ID=your-site-id-here
NETLIFY_AUTH_TOKEN=your-personal-access-token-here

# Optional: set the public URL of your deployed site (used to build NFC tag URLs)
NEXT_PUBLIC_SITE_URL=https://your-site.netlify.app
